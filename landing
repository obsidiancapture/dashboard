<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Obsidian Capture</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #f0ede8;
  --bg2: #e8e4dd;
  --tx: #1a1714;
  --tx2: #6b6560;
  --tx3: #a09890;
  --blob1: rgba(193,168,128,.55);
  --blob2: rgba(210,185,150,.4);
  --blob3: rgba(180,155,120,.35);
  --card-bg: rgba(255,252,248,.45);
  --card-border: rgba(255,255,255,.7);
  --card-shadow: 0 8px 40px rgba(100,80,50,.1), 0 1px 0 rgba(255,255,255,.8) inset;
}

html { font-size: 15px; -webkit-font-smoothing: antialiased; }

body {
  background: var(--bg);
  color: var(--tx);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* ── BLOBS ── */
.blob-wrap {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  animation: drift 18s ease-in-out infinite;
}

.blob-1 {
  width: 600px; height: 500px;
  background: var(--blob1);
  top: -100px; left: -80px;
  animation-duration: 20s;
}

.blob-2 {
  width: 500px; height: 450px;
  background: var(--blob2);
  top: 30%; right: -100px;
  animation-duration: 25s;
  animation-delay: -8s;
}

.blob-3 {
  width: 450px; height: 400px;
  background: var(--blob3);
  bottom: -80px; left: 30%;
  animation-duration: 22s;
  animation-delay: -14s;
}

.blob-4 {
  width: 300px; height: 280px;
  background: rgba(215,195,160,.3);
  top: 50%; left: 20%;
  animation-duration: 30s;
  animation-delay: -5s;
}

@keyframes drift {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(30px, -20px) scale(1.03); }
  50% { transform: translate(-20px, 30px) scale(0.97); }
  75% { transform: translate(20px, 10px) scale(1.02); }
}

/* ── GRAIN ── */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  opacity: .5;
}

/* ── LAYOUT ── */
.page { position: relative; z-index: 2; }

/* ── NAV ── */
nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 40px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-logo {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: 18px;
  color: var(--tx);
  letter-spacing: -.01em;
}

.nav-logo em {
  font-style: italic;
  color: var(--tx2);
}

.nav-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,252,248,.55);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,.75);
  border-radius: 100px;
  padding: 8px 18px;
  font-size: 13px;
  font-weight: 400;
  color: var(--tx2);
  box-shadow: 0 2px 12px rgba(100,80,50,.08), inset 0 1px 0 rgba(255,255,255,.9);
  cursor: pointer;
  transition: all .2s;
}

.nav-pill:hover {
  background: rgba(255,252,248,.75);
  color: var(--tx);
}

.nav-pill .dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--tx3);
}

.nav-cta {
  background: rgba(26,23,20,.85);
  backdrop-filter: blur(20px);
  color: rgba(255,252,248,.9);
  border: 1px solid rgba(26,23,20,.5);
}

.nav-cta:hover {
  background: var(--tx);
  color: #fff;
}

/* ── HERO ── */
.hero {
  text-align: center;
  padding: 80px 40px 60px;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,252,248,.5);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,.7);
  border-radius: 100px;
  padding: 5px 16px 5px 10px;
  font-size: 12px;
  color: var(--tx3);
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 32px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.9);
}

.hero-tag .pulse {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #8b7355;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .4; transform: scale(.8); }
}

.hero-title {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: clamp(52px, 8vw, 96px);
  font-weight: 400;
  line-height: 1;
  letter-spacing: -.03em;
  color: var(--tx);
  margin-bottom: 10px;
}

.hero-title em {
  font-style: italic;
  color: var(--tx2);
}

.hero-sub {
  font-size: 16px;
  color: var(--tx3);
  font-weight: 300;
  letter-spacing: .01em;
  margin-bottom: 48px;
}

/* ── CARDS GRID ── */
.cards-section {
  padding: 20px 40px 80px;
  max-width: 1200px;
  margin: 0 auto;
}

.cards-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  align-items: end;
}

/* Cartes avec hauteurs différentes pour l'effet GreenMotive */
.card:nth-child(1) { margin-top: 40px; }
.card:nth-child(2) { margin-top: 0; }
.card:nth-child(3) { margin-top: 60px; }

.card {
  background: var(--card-bg);
  backdrop-filter: blur(28px) saturate(160%);
  -webkit-backdrop-filter: blur(28px) saturate(160%);
  border: 1px solid var(--card-border);
  border-radius: 20px;
  padding: 32px 28px 36px;
  box-shadow: var(--card-shadow);
  cursor: pointer;
  transition: all .35s cubic-bezier(.4,0,.2,1);
  position: relative;
  overflow: hidden;
  animation: cardIn .6s cubic-bezier(.4,0,.2,1) both;
}

.card:nth-child(1) { animation-delay: .1s; }
.card:nth-child(2) { animation-delay: .2s; }
.card:nth-child(3) { animation-delay: .3s; }

@keyframes cardIn {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,252,248,.6) 0%, rgba(255,252,248,.1) 100%);
  opacity: 0;
  transition: opacity .3s;
  border-radius: inherit;
}

.card:hover {
  transform: translateY(-8px) scale(1.01);
  box-shadow: 0 24px 60px rgba(100,80,50,.18), 0 1px 0 rgba(255,255,255,.9) inset;
  border-color: rgba(255,255,255,.9);
}

.card:hover::before { opacity: 1; }

.card-tag {
  font-size: 11px;
  font-weight: 500;
  color: var(--tx3);
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-bottom: 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-tag-pill {
  background: rgba(26,23,20,.06);
  border: 1px solid rgba(26,23,20,.08);
  border-radius: 100px;
  padding: 3px 10px;
  font-size: 10px;
}

.card-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  background: rgba(26,23,20,.06);
  border: 1px solid rgba(26,23,20,.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  margin-bottom: 80px;
  transition: all .2s;
}

.card:hover .card-icon {
  background: rgba(26,23,20,.1);
  transform: scale(1.05);
}

.card-title {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: 22px;
  font-weight: 400;
  line-height: 1.15;
  letter-spacing: -.01em;
  color: var(--tx);
  margin-bottom: 10px;
}

.card-desc {
  font-size: 13px;
  color: var(--tx3);
  line-height: 1.6;
  font-weight: 300;
}

/* Carte centrale plus grande */
.card.featured {
  padding-top: 44px;
  padding-bottom: 48px;
}

.card.featured .card-icon {
  margin-bottom: 100px;
  width: 52px; height: 52px;
  border-radius: 14px;
}

.card.featured .card-title {
  font-size: 26px;
}

/* ── BOTTOM BAR ── */
.bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px 60px;
  max-width: 1200px;
  margin: 32px auto 0;
}

.bottom-pill {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,252,248,.45);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,.7);
  border-radius: 100px;
  padding: 10px 20px;
  font-size: 13px;
  color: var(--tx2);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.9);
}

.bottom-cta {
  background: rgba(26,23,20,.88);
  backdrop-filter: blur(20px);
  color: rgba(255,252,248,.9);
  border: 1px solid rgba(26,23,20,.5);
  border-radius: 100px;
  padding: 12px 28px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
  transition: all .2s;
  box-shadow: 0 4px 20px rgba(26,23,20,.2);
}

.bottom-cta:hover {
  background: var(--tx);
  box-shadow: 0 8px 30px rgba(26,23,20,.35);
  transform: translateY(-1px);
}

/* ── STATS ROW ── */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  padding: 0 40px 40px;
  max-width: 1200px;
  margin: 0 auto;
}

.stat-card {
  flex: 1;
  background: rgba(255,252,248,.4);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,.65);
  border-radius: 14px;
  padding: 20px 24px;
  text-align: center;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.8);
  transition: all .2s;
}

.stat-card:hover {
  background: rgba(255,252,248,.6);
  transform: translateY(-3px);
}

.stat-num {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: 32px;
  font-weight: 400;
  color: var(--tx);
  letter-spacing: -.02em;
  line-height: 1;
  margin-bottom: 4px;
}

.stat-num em { font-style: italic; color: var(--tx2); }

.stat-lbl {
  font-size: 11px;
  color: var(--tx3);
  letter-spacing: .06em;
  text-transform: uppercase;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  nav { padding: 16px 20px; }
  .hero { padding: 60px 20px 40px; }
  .cards-section { padding: 10px 20px 60px; }
  .cards-row { grid-template-columns: 1fr; gap: 12px; }
  .card:nth-child(1), .card:nth-child(2), .card:nth-child(3) { margin-top: 0; }
  .bottom-row { flex-direction: column; gap: 16px; padding: 0 20px 40px; }
  .stats-row { flex-direction: column; gap: 8px; padding: 0 20px 40px; }
  .stat-card { width: 100%; }
}
</style>
</head>
<body>

<div class="blob-wrap">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
  <div class="blob blob-4"></div>
</div>

<div class="page">
  <nav>
    <div class="nav-logo">Obsidian<em> Capture</em></div>
    <div style="display:flex;gap:8px;align-items:center">
      <div class="nav-pill">
        <span class="dot"></span>
        Menu
      </div>
      <div class="nav-pill">Découvrir →</div>
    </div>
    <button class="nav-pill nav-cta">Prendre contact</button>
  </nav>

  <section class="hero">
    <div class="hero-tag">
      <span class="pulse"></span>
      Studio de contenu visuel
    </div>
    <h1 class="hero-title">Obsidian<br><em>Capture</em></h1>
    <p class="hero-sub">Vidéaste & stratège contenu — transformez votre présence en ligne</p>
  </section>

  <section class="cards-section">
    <div class="cards-row">

      <div class="card">
        <div class="card-tag">
          Stratégie
          <span class="card-tag-pill">01</span>
        </div>
        <div class="card-icon">◎</div>
        <div class="card-title">Prospection &amp; Pipeline</div>
        <p class="card-desc">Gérez vos contacts, suivez vos devis et visualisez votre pipeline commercial en temps réel.</p>
      </div>

      <div class="card featured">
        <div class="card-tag">
          Production
          <span class="card-tag-pill">02</span>
        </div>
        <div class="card-icon">▶</div>
        <div class="card-title">Contenu &amp; Réels</div>
        <p class="card-desc">Planifiez vos batches de réels semaine par semaine, suivez les statuts et mesurez la performance de chaque post.</p>
      </div>

      <div class="card">
        <div class="card-tag">
          Analyse
          <span class="card-tag-pill">03</span>
        </div>
        <div class="card-icon">↗</div>
        <div class="card-title">Réseaux Sociaux</div>
        <p class="card-desc">Suivez l'évolution de vos abonnés, taux d'engagement et vues mois après mois sur toutes les plateformes.</p>
      </div>

    </div>
  </section>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num">30<em>+</em></div>
      <div class="stat-lbl">Réels / mois</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">3<em>x</em></div>
      <div class="stat-lbl">Croissance moyenne</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">∞</div>
      <div class="stat-lbl">Possibilités</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">◈</div>
      <div class="stat-lbl">Clients actifs</div>
    </div>
  </div>

  <div class="bottom-row">
    <div class="bottom-pill">
      <span style="font-size:14px">◈</span>
      Espace client disponible
    </div>
    <button class="bottom-cta">Accéder au dashboard →</button>
  </div>
</div>

</body>
</html>
